{
  "name": "codex-antigravity-bridge",
  "version": "0.1.0",
  "description": "Plugin-first Antigravity port of the OpenAI Codex Claude Code plugin workflow.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "codex-antigravity-bridge": "./dist/src/index.js"
  },
  "files": [
    "dist/",
    ".claude-plugin/",
    "agents/",
    "commands/",
    "docs/",
    "hooks.json",
    "legacy-mcp/",
    "plugin.json",
    "prompts/",
    "schemas/",
    "scripts/",
    "skills/",
    "vendor/openai-codex-claude-plugin/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "plugin:install": "node scripts/install-antigravity-plugin.mjs",
    "plugin:validate": "agy plugin validate .",
    "start": "node dist/src/index.js",
    "smoke:tools": "node dist/tests/smoke-list-tools.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.18"
  }
}
